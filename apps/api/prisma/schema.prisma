// Prisma schema — the single source of truth for the database structure.
// After editing, run `npm run db:migrate` to generate & apply a migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

/// An account. Auth-critical fields only; profile data lives in UserProfile.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  profile       UserProfile?
  calculations  Calculation[]
  refreshTokens RefreshToken[]

  @@map("users")
}

/// Optional 1:1 profile, kept separate so the auth table stays lean.
model UserProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  displayName String?
  currency    String  @default("USD")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

/// A calculator kind (e.g. "salary"). Lets new calculators be added as
/// data rather than code.
model CalculatorType {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  config    Json?
  createdAt DateTime @default(now())

  calculations Calculation[]

  @@map("calculator_types")
}

/// A saved calculation owned by exactly one user. Inputs/results are JSON so
/// each calculator can define its own shape without a schema migration.
model Calculation {
  id               String   @id @default(uuid())
  userId           String
  calculatorTypeId String?
  calculatorSlug   String
  title            String?
  inputs           Json
  results          Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  calculatorType CalculatorType? @relation(fields: [calculatorTypeId], references: [id])

  @@index([userId])
  @@map("calculations")
}

/// Hashed refresh tokens, enabling revocation ("log out" / "manage devices").
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
