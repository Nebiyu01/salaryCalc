{
  "name": "salary-calc",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @salary-calc/web",
    "dev:api": "npm run start:dev --workspace @salary-calc/api",
    "build": "npm run build --workspaces --if-present",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate --workspace @salary-calc/api",
    "db:studio": "npm run prisma:studio --workspace @salary-calc/api"
  }
}
